{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://schemas.kadencewp.com/design-tokens/dtcg.schema.json",
    "title": "Kadence Blocks DTCG document",
    "description": "Design Tokens Community Group document for the Kadence Blocks Design Tokens module. Generated from the PHP source of truth (Token_Type, Alias); do not edit by hand.",
    "type": "object",
    "properties": {
        "$description": {
            "type": "string"
        },
        "$extensions": {
            "type": "object"
        }
    },
    "patternProperties": {
        "^[^$].*$": {
            "$ref": "#/definitions/node"
        }
    },
    "additionalProperties": false,
    "definitions": {
        "alias": {
            "type": "string",
            "pattern": "^\\{[\\w.-]+\\}$",
            "description": "A whole-string DTCG alias, e.g. \"{primitive.color.brand.primary}\"."
        },
        "node": {
            "type": "object",
            "oneOf": [
                {
                    "$ref": "#/definitions/leaf"
                },
                {
                    "$ref": "#/definitions/group"
                }
            ]
        },
        "group": {
            "type": "object",
            "properties": {
                "$description": {
                    "type": "string"
                },
                "$extensions": {
                    "type": "object"
                }
            },
            "patternProperties": {
                "^[^$].*$": {
                    "$ref": "#/definitions/node"
                }
            },
            "additionalProperties": false
        },
        "leaf": {
            "type": "object",
            "required": [
                "$type",
                "$value"
            ],
            "properties": {
                "$type": {
                    "enum": [
                        "color",
                        "dimension",
                        "fontFamily",
                        "shadow",
                        "typography"
                    ]
                },
                "$value": true,
                "$description": {
                    "type": "string"
                },
                "$extensions": {
                    "type": "object"
                }
            },
            "oneOf": [
                {
                    "properties": {
                        "$type": {
                            "const": "color"
                        },
                        "$value": {
                            "$ref": "#/definitions/colorValue"
                        }
                    },
                    "required": [
                        "$type",
                        "$value"
                    ]
                },
                {
                    "properties": {
                        "$type": {
                            "const": "dimension"
                        },
                        "$value": {
                            "$ref": "#/definitions/dimensionValue"
                        }
                    },
                    "required": [
                        "$type",
                        "$value"
                    ]
                },
                {
                    "properties": {
                        "$type": {
                            "const": "fontFamily"
                        },
                        "$value": {
                            "$ref": "#/definitions/fontFamilyValue"
                        }
                    },
                    "required": [
                        "$type",
                        "$value"
                    ]
                },
                {
                    "properties": {
                        "$type": {
                            "const": "shadow"
                        },
                        "$value": {
                            "$ref": "#/definitions/shadowValue"
                        }
                    },
                    "required": [
                        "$type",
                        "$value"
                    ]
                },
                {
                    "properties": {
                        "$type": {
                            "const": "typography"
                        },
                        "$value": {
                            "$ref": "#/definitions/typographyValue"
                        }
                    },
                    "required": [
                        "$type",
                        "$value"
                    ]
                }
            ],
            "additionalProperties": false
        },
        "colorValue": {
            "anyOf": [
                {
                    "$ref": "#/definitions/alias"
                },
                {
                    "type": "string"
                }
            ]
        },
        "dimensionValue": {
            "anyOf": [
                {
                    "$ref": "#/definitions/alias"
                },
                {
                    "type": "string"
                }
            ]
        },
        "fontFamilyValue": {
            "anyOf": [
                {
                    "$ref": "#/definitions/alias"
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                }
            ]
        },
        "shadowValue": {
            "anyOf": [
                {
                    "$ref": "#/definitions/alias"
                },
                {
                    "type": "object",
                    "required": [
                        "color",
                        "offsetX",
                        "offsetY",
                        "blur",
                        "spread"
                    ],
                    "properties": {
                        "color": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": "string"
                                }
                            ]
                        },
                        "offsetX": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": "string"
                                }
                            ]
                        },
                        "offsetY": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": "string"
                                }
                            ]
                        },
                        "blur": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": "string"
                                }
                            ]
                        },
                        "spread": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": "string"
                                }
                            ]
                        }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "typographyValue": {
            "anyOf": [
                {
                    "$ref": "#/definitions/alias"
                },
                {
                    "type": "object",
                    "required": [
                        "fontFamily",
                        "fontSize",
                        "fontWeight",
                        "lineHeight"
                    ],
                    "properties": {
                        "fontFamily": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    },
                                    "minItems": 1
                                }
                            ]
                        },
                        "fontSize": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": "string"
                                }
                            ]
                        },
                        "fontWeight": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": [
                                        "string",
                                        "number"
                                    ]
                                }
                            ]
                        },
                        "lineHeight": {
                            "anyOf": [
                                {
                                    "$ref": "#/definitions/alias"
                                },
                                {
                                    "type": [
                                        "string",
                                        "number"
                                    ]
                                }
                            ]
                        }
                    },
                    "additionalProperties": false
                }
            ]
        }
    }
}
